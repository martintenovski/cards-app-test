{
  "expo": {
    "name": "Pocket ID",
    "slug": "cards-app",
    "scheme": ["pocketid", "cards-app"],
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#ffffff",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Pocket ID to use Face ID so only you can open your saved cards and documents."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#239BFF"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {}
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "com.tenovski.cardsapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is required to scan identity documents and bank cards",
        "NFCReaderUsageDescription": "Allow Cards App to use NFC to read compatible cards and tags when you choose to scan them.",
        "NSUserNotificationsUsageDescription": "Pocket ID uses notifications to remind you before cards and documents expire.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#239BFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tenovski.cardsapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b468596e-d8da-4ed6-b9aa-82ff11ef49d5"
      }
    }
  }
}
