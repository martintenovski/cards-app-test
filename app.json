{
  "expo": {
    "name": "Pocket ID",
    "slug": "cards-app",
    "scheme": "pocketid",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#239bff",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#239bff"
    },
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Pocket ID to use Face ID so only you can open your saved cards and documents."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {}
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "ios": {
      "icon": "./assets/ios-logo.png",
      "supportsTablet": true,
      "buildNumber": "4",
      "bundleIdentifier": "com.tenovski.cardsapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is required to scan identity documents and bank cards",
        "NSUserNotificationsUsageDescription": "Pocket ID uses notifications to remind you before cards and documents expire.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/droid-foreground.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/droid-foreground.png",
        "backgroundImage": "./assets/droid-icon-background.png",
        "monochromeImage": "./assets/droid-monochrome.png"
      },
      "versionCode": 4,
      "predictiveBackGestureEnabled": false,
      "package": "com.tenovski.cardsapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b468596e-d8da-4ed6-b9aa-82ff11ef49d5"
      }
    }
  }
}
