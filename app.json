{
  "expo": {
    "name": "Pocket ID",
    "slug": "cards-app",
    "scheme": "pocketid",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#1C1E21",
    "splash": {
      "image": "./assets/ios-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1E21",
      "imageWidth": 88
    },
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Allow Pocket ID to use the camera so you can scan cards and documents into editable drafts."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Pocket ID to use Face ID so only you can open your saved cards and documents."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {}
        }
      ],
      [
        "./node_modules/rn-mlkit-ocr/app.plugin.js",
        {
          "ocrModels": ["latin"],
          "ocrUseBundled": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "./plugins/withAndroidSplashRoundedCorners",
      [
        "expo-splash-screen",
        {
          "image": "./assets/ios-logo-rounded.png",
          "resizeMode": "contain",
          "backgroundColor": "#1C1E21",
          "imageWidth": 88
        }
      ]
    ],
    "ios": {
      "icon": "./assets/ios-logo.png",
      "supportsTablet": true,
      "buildNumber": "6",
      "bundleIdentifier": "com.tenovski.cardsapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Pocket ID to use the camera so you can scan cards and documents into editable drafts.",
        "NSUserNotificationsUsageDescription": "Pocket ID uses notifications to remind you before cards and documents expire.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/droid-foreground.png",
      "splash": {
        "image": "./assets/ios-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#1C1E21",
        "imageWidth": 200
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/droid-foreground.png",
        "backgroundImage": "./assets/droid-icon-background.png",
        "monochromeImage": "./assets/droid-monochrome.png"
      },
      "versionCode": 49,
      "predictiveBackGestureEnabled": false,
      "package": "com.tenovski.cardsapp",
      "permissions": ["android.permission.POST_NOTIFICATIONS"]
    },
    "androidStatusBar": {
      "backgroundColor": "#1C1E21",
      "barStyle": "light-content",
      "translucent": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b468596e-d8da-4ed6-b9aa-82ff11ef49d5"
      }
    }
  }
}
